# ════════════════════════════════════════════════════════════════
# AKP 프로젝트 API 키 템플릿
# ─────────────────────────────────────────────────────────────
# 사용법:
#   copy .env.example .env    (Windows)
#   cp .env.example .env      (Mac/Linux)
# 그 후 .env를 열어 실제 값으로 교체하세요.
#
# ⚠️  .env 파일은 절대 GitHub에 커밋하지 마세요.
#     이 파일(.env.example)만 커밋 가능합니다.
# ════════════════════════════════════════════════════════════════

# Mathpix API (수식 OCR)
# 발급: https://accounts.mathpix.com
MATHPIX_APP_ID=your_mathpix_app_id_here
MATHPIX_APP_KEY=your_mathpix_app_key_here

# Anthropic API (Claude 구조화)
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx_your_claude_key_here
